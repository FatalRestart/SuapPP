{
  "name": "SuapPP",
  "description": "Extensão auxiliar para o sistema unificado de administração pública",
  "version": "1.0.1",
  "manifest_version": 3,
  "permissions": [
    "scripting",
    "tabs",
    "storage"
  ],
  "icons": {
    "16": "./icons/icon16.png",
    "32": "./icons/icon32.png",
    "48": "./icons/icon48.png",
    "128": "./icons/icon128.png"
  },
  "host_permissions": [
    "https://suap.ifsp.edu.br/*"
  ],
  "action": {
    "default_popup": "index.html"
  }
}
