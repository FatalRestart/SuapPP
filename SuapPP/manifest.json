{
  "name": "SuapPP",
  "description": "Extensão auxiliar para o sistema unificado de administração pública",
  "version": "1.0.2",
  "manifest_version": 3,
  "permissions": [
    "scripting",
    "activeTab",
    "storage"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "host_permissions": [
    "https://suap.ifsp.edu.br/*"
  ],
  "action": {
    "default_popup": "index.html"
  }
}
